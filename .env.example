# Gold's backend — copy this to .env and fill in values
# .env is never committed to git

PORT=3001
NODE_ENV=development

# Path to SQLite file (leave blank to use default: server/data/database.sqlite)
DB_PATH=

# JWT — change this to a long random string in production
JWT_SECRET=change-this-to-a-random-string

# Admin credentials
# Run: node server/scripts/hash-password.js yourpassword
# Then paste the output hash below
ADMIN_EMAIL=admin@golds.co.il
ADMIN_PASSWORD_HASH=

# Production only: restrict CORS to your domain
ALLOWED_ORIGIN=https://yourdomain.co.il

# Notification recipients
OWNER_EMAIL=
OWNER_WHATSAPP=

# Notification providers (e.g. sendgrid, twilio, vonage)
EMAIL_PROVIDER=
WHATSAPP_PROVIDER=